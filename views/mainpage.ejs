<!DOCTYPE html>
<html>
    <head>
        <title>Облік</title>

        <link rel="stylesheet" type="text/css" href="/styles.css">
    </head>
    <body id="main-page">
        <% if (user.role === 'admin' || user.role === "teacher") { %>
            <h1 id="main-page-title">Список обладнання</h1>
        <% } else { %>
            <h1 id="main-page-title">Моє обладнання</h1>
        <% } %>

        <form action="/logout" method="POST">
            <button type="submit" id="logout-button">Вийти</button>
        </form>

        <% if (user && user.role === 'admin') { %>
            <button id="admin-panel-button">Панель адміністрування</button>
        <% } %>

        <dialog id="adminModal">
            <div class="admin-tabs">
                <button type="button" class="admin-tab-button active" data-tab="users">Користувачі</button>
                <button type="button" class="admin-tab-button" data-tab="equipment">Обладнання</button>
                <button type="button" class="admin-tab-button" data-tab="db">База даних</button>
            </div>

            <div class="admin-tab-content active" id="admin-tab-users">
                <h3>Керування користувачами</h3>
                <button type="button" id="create-user-button">Створити користувача</button>
                <button type="button" id="delete-user-button">Видалити користувача</button>
            </div>

            <div class="admin-tab-content" id="admin-tab-equipment">
                <h3>Керування обладнанням</h3>
                <button class="add-btn"
                    data-id
                    data-name
                    data-type
                    data-serial
                    data-status
                    data-description>
                    Додати обладнання
                </button>
                <form action="/warehouse-report">
                    <button type="submit">Звіт складу</button>
                </form>
            </div>

            <div class="admin-tab-content" id="admin-tab-db">
                <p>Поки що пусто</p>
            </div>

            <button type="button" id="adminCloseBtn">Закрити</button>
        </dialog>


        <table border="1"> <thead>
                <tr>
                    <th>ID</th>
                    <th>Назва</th>
                    <th>Тип</th>
                    <th>Серійний номер</th>
                    <th>Статус</th>
                    <th>Призначено користувачу</th>
                    <th>Опис</th>
                    <th>Дія</th>
                </tr>
            </thead>
            <tbody>
                <% items.forEach(function(item) { %>
                <tr>
                    <td><%= item.id %></td>
                    <td><%= item.name %></td>
                    <td><%= item.type %></td>
                    <td><%= item.serial %></td>
                    <td><%= item.status %></td>
                    <td><%= assignmentByEquipmentId && assignmentByEquipmentId[Number(item.id)] ? assignmentByEquipmentId[Number(item.id)] : 'Не призначено' %></td>
                    <td><%= item.description %></td>
                    <% if (user && user.role === 'admin') { %>
                    <td>
                        <form action="/remove" method="POST"
                            style="display:inline;">
                            <input type="hidden" name="id"
                                value="<%= item.id %>">
                            <button type="submit"
                                id="delete-button">Видалити</button>
                        </form>
                        <button class="edit-btn"
                            data-id="<%= item.id %>"
                            data-name="<%= item.name %>"
                            data-type="<%= item.type %>"
                            data-serial="<%= item.serial %>"
                            data-status="<%= item.status %>"
                            data-description="<%= item.description %>">
                            Редагувати
                        </button>
                        
                        <% if (assignedEquipmentIds && assignedEquipmentIds.includes(Number(item.id))) { %>
                            <form action="/unassign-item" method="POST" style="display:inline;">
                                <input type="hidden" name="id" value="<%= item.id %>">
                                <button type="submit">Зняти призначення</button>
                            </form>
                        <% } else if (item.status === 'ремонт') { %>
                            <form action="/fix-item" method="POST" style="display:inline;">
                                <input type="hidden" name="id" value="<%= item.id %>">
                                <button type="submit">Відремонтовано</button>
                            </form>
                        <% } else { %>
                            <button class="assignBtn"
                                data-id="<%= item.id %>"
                                data-name="<%= item.name %>"
                                data-type="<%= item.type %>"
                                data-serial="<%= item.serial %>"
                                data-status="<%= item.status %>"
                                data-description="<%= item.description %>">
                                Призначити користувачу
                            </button>
                        <% } %>
                    </td>
                    <% } %>
                </tr>

                <% }); %>
            </tbody>
        </table>

        <dialog id="editModal">
            <form action="/update-item" method="POST">
                <input type="hidden" name="id" id="modalId">
                <input type="text" name="name" id="modalName" placeholder="Назва">
                <select name="type" id="modalType">
                    <option value="контролер">Контролер</option>
                    <option value="датчик">Датчик</option>
                    <option value="модуль">Модуль</option>
                </select>
                <input type="text" name="serial" id="modalSerial"
                    placeholder="Серійний номер">

                <textarea name="description" id="modalDescription"
                    placeholder="Технічні характеристики"></textarea>

                <select name="status" id="modalStatus">
                    <option value="вільне">Вільне</option>
                    <option value="ремонт">Ремонт</option>
                </select>
                <button type="button" id="closeBtn">Скасувати</button>
                <button type="submit">Зберегти</button>
            </form>
        </dialog>

        <dialog id="assignModal">
            <form action="/assign-item" method="POST">
                <input type="hidden" name="id" id="assignModalId">
                <select name="userId" id="assignModalUser">
                    <% users.forEach(function(user) { %>
                        <option value="<%= user.id %>"><%= user.username %></option>
                    <% }); %>
                </select>
                <button type="button" id="assignCloseBtn">Скасувати</button>
                <button type="submit">Призначити</button>
            </form>
        </dialog>

        <dialog id="addModal">
            <form action="/add-item" method="POST">
                <!-- <input type="text" name="id" id="modalId" placeholder="ID"> -->
                <input type="text" name="name" id="modalName" placeholder="Назва">
                <select name="type" id="modalType">
                    <option value="контролер">Контролер</option>
                    <option value="датчик">Датчик</option>
                    <option value="модуль">Модуль</option>
                </select>
                <input type="text" name="serial" id="modalSerial"
                    placeholder="Серійний номер">

                <textarea name="description" id="modalDescription"
                    placeholder="Технічні характеристики"></textarea>

                <select name="status" id="modalStatus">
                    <option value="вільне">Вільне</option>
                    <option value="ремонт">Ремонт</option>
                </select>
                <button type="button" id="addCloseBtn">Скасувати</button>
                <button type="submit">Додати компонент</button>
            </form>
        </dialog>

        <% if (user && user.role === 'admin') { %>
            <button class="add-btn"
                data-id
                data-name
                data-type
                data-serial
                data-status
                data-description>
                Додати обладнання
            </button>
            <!-- <button id="create-user-button">Створити користувача</button> -->
            <form action="/warehouse-report">
                <button type="submit">Звіт складу</button>
            </form>
        <% } %>

        <dialog id="addUserModal">
            <form action="/add-user" method="POST">
                <input type="text" name="username" id="modalUsername" placeholder="Логін">
                <input type="password" name="password" id="modalPassword" placeholder="Пароль">
                <select name="role" id="modalRole">
                    <option value="user">Користувач</option>
                    <option value="admin">Адміністратор</option>
                    <option value="teacher">Викладач</option>
                </select>
                <button type="button" id="addUserCloseBtn">Скасувати</button>
                <button type="submit">Створити користувача</button>
            </form>
        </dialog>

        
        <dialog id="delUserModal">
            <form action="/delete-user" method="POST">
                <select name="id" id="deleteModalUser">
                    <% users.forEach(function(user) { %>
                        <option value="<%= user.id %>"><%= user.username %></option>
                    <% }); %>
                </select>
                <button type="button" id="delUserCloseBtn">Скасувати</button>
                <button type="submit">Видалити користувача</button>
            </form>
        </dialog>


    </body>
    <script>
        const editModal = document.getElementById('editModal');
        const addModal = document.getElementById('addModal');
        const addUserModal = document.getElementById('addUserModal');
        const assignModal = document.getElementById('assignModal');
        const adminPanelButton = document.getElementById('admin-panel-button');
        const adminModal = document.getElementById('adminModal');
        const deleteUserModal = document.getElementById('delUserModal');

        const closeBtn = document.getElementById('closeBtn');
        const addCloseBtn = document.getElementById('addCloseBtn');
        const addUserCloseBtn = document.getElementById('addUserCloseBtn');
        const assignCloseBtn = document.getElementById('assignCloseBtn');
        const adminCloseBtn = document.getElementById('adminCloseBtn');
        const deleteUserCloseBtn = document.getElementById('delUserCloseBtn');
        
        const inputId = document.getElementById('modalId');
        const inputName = document.getElementById('modalName');
        const selectType = document.getElementById('modalType');
        const inputSerial = document.getElementById('modalSerial');
        const selectStatus = document.getElementById('modalStatus');
        const inputDescription = document.getElementById('modalDescription');

        const inputUsername = document.getElementById('modalUsername');
        const inputPassword = document.getElementById('modalPassword');
        const selectRole = document.getElementById('modalRole');
        
        const assignModalId = document.getElementById('assignModalId');
        const assignModalUser = document.getElementById('assignModalUser');
        const adminTabButtons = document.querySelectorAll('.admin-tab-button');
        const adminTabContents = document.querySelectorAll('.admin-tab-content');

        const setAdminTab = (tabName) => {
            adminTabButtons.forEach((button) => {
                button.classList.toggle('active', button.dataset.tab === tabName);
            });

            adminTabContents.forEach((content) => {
                content.classList.toggle('active', content.id === `admin-tab-${tabName}`);
            });
        };

        if (adminCloseBtn && adminModal) {
            adminCloseBtn.addEventListener('click', () => {
                adminModal.close();
            });
        }

        document.addEventListener('click', (e) => {
            if (e.target.classList.contains('edit-btn')) {
                
                const id = e.target.dataset.id;
                const name = e.target.dataset.name;
                const type = e.target.dataset.type;
                const serial = e.target.dataset.serial;
                const status = e.target.dataset.status;
                const description = e.target.dataset.description;


                inputId.value = id;
                inputName.value = name;
                selectType.value = type;
                inputSerial.value = serial;
                selectStatus.value = status;
                inputDescription.value = description;

                editModal.showModal();
                
        closeBtn.addEventListener('click', () => {
            editModal.close();
        });
            }
            else if (e.target.classList.contains('add-btn')) {
                const id = e.target.dataset.id;
                const name = e.target.dataset.name;
                const type = e.target.dataset.type;
                const serial = e.target.dataset.serial;
                const status = e.target.dataset.status;
                const description = e.target.dataset.description;


                inputId.value = id;
                inputName.value = name;
                selectType.value = type;
                inputSerial.value = serial;
                selectStatus.value = status;
                inputDescription.value = description;

                addModal.showModal();

                
        addCloseBtn.addEventListener('click', () => {
            addModal.close();
        });
            }
                else if (e.target.id === 'create-user-button') {
                    // Clear form fields for new user
                    inputUsername.value = '';
                    inputPassword.value = '';
                    selectRole.value = 'user';

                    addUserModal.showModal();
    
                    const addUserCloseBtn = document.getElementById('addUserCloseBtn');
                    addUserCloseBtn.addEventListener('click', () => {
                        addUserModal.close();
                    });
                }
            else if (e.target.classList.contains('assignBtn')) {
                    const id = e.target.dataset.id;
                    assignModalId.value = id;
                    assignModal.showModal();
    
                    const assignCloseBtn = document.getElementById('assignCloseBtn');
                    assignCloseBtn.addEventListener('click', () => {
                        assignModal.close();
                    });
                }
            else if (e.target.id === 'admin-panel-button') {
                setAdminTab('users');
                adminModal.showModal();
            }
            else if (e.target.classList.contains('admin-tab-button')) {
                setAdminTab(e.target.dataset.tab);
            }
            else if (e.target.id === 'delete-user-button') {
                deleteUserModal.showModal();

                const deleteUserCloseBtn = document.getElementById('delUserCloseBtn');
                deleteUserCloseBtn.addEventListener('click', () => {
                    deleteUserModal.close();
                });
            }
        });

</script>
</html>