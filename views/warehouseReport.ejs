<!DOCTYPE html>
<html>
<head>
    <title>Звіти складу</title>
    <link rel="stylesheet" type="text/css" href="/styles.css">
</head>
<body>
    <h1 id="warehouse-report-title">Звіт складу</h1>
    <p> Загальна кількість обладнання: <%= totalEquipment %></p>
    <p> Вільне обладнання: <%= freeEquipment %></p>
    <p> Призначене обладнання: <%= assignedEquipment %></p>
    <p> Пошкоджене обладнання: <%= damagedEquipment %></p>
    <table id="warehouse-report-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Назва</th>
                <th>Тип</th>
                <th>Серійний номер</th>
                <th>Статус</th>
                <th>Опис</th>
            </tr>
        </thead>
        <tbody>
            <% equipment.forEach(item => { %>
                <tr>
                    <td><%= item.id %></td>
                    <td><%= item.name %></td>
                    <td><%= item.type %></td>
                    <td><%= item.serial %></td>
                    <td><%= item.status %></td>
                    <td><%= item.description %></td>
                </tr>
            <% }) %>
        </tbody>
</body>
</html>